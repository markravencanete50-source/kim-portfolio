rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // True when the caller has an admin profile in `user/{uid}`.
    // get()/exists() inside rules bypass the read rules below, so this works
    // regardless of who can read the `user` collection from the client.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/user/$(request.auth.uid))
        && get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin profiles. A signed-in user may read only their own record (the
    // dashboard checks role from it). Records are provisioned manually in the
    // Firebase console, so client writes are closed.
    match /user/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Leads: anyone can create (the public booking form); only an admin can
    // read or update. Deletes are never allowed from the client.
    match /leads/{doc} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.name.size() < 200
                    && request.resource.data.email.size() < 200;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Page views: append-only from the public site; only an admin can read.
    match /pageviews/{doc} {
      allow create: if true;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }
  }
}
